/* Catppuccin Mocha */
* {
    background:     #1e1e2eD9;  /* Base 85% opacity */
    background-alt: #313244FF;  /* Surface0 - alternate row */
    foreground:     #cdd6f4FF;  /* Text */
    selected:       #89b4faFF;  /* Blue */
    active:         #a6e3a1FF;  /* Green */
    urgent:         #f38ba8FF;  /* Red */
}
