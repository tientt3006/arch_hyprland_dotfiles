# ==============================================================================
# Tệp chứa các biến môi trường BÍ MẬT (API Keys, Tokens, Passwords)
# File này đã được thêm vào .gitignore, do đó sẽ KHÔNG BAO GIỜ bị đẩy lên Git.
# ==============================================================================

# Ví dụ về các API Key của LLM:
# export OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx"
# export ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxx"
# export GEMINI_API_KEY="AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxx"

# Nếu bạn có các API Key hoặc Token cá nhân khác, hãy khai báo dưới dạng:
# export TEN_BIEN="GiaTriCuaBan"
